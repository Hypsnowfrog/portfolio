---
import type { NavigationSettings } from '../lib/content';
import { withBase } from '../lib/url';
interface Props { items: NavigationSettings['items']; label: string; currentPath: string; }
const { items, label, currentPath } = Astro.props;
---
<details>
  <summary>{label}</summary>
  <nav aria-label="Navigation mobile">
    <ul>{items.filter((item) => item.enabled).map((item) => <li><a href={withBase(item.url)} aria-current={currentPath === item.url ? 'page' : undefined}>{item.label}</a></li>)}</ul>
  </nav>
</details>
<style>
  details { position: relative; }
  summary { cursor: pointer; font-size: .875rem; }
  nav { position: absolute; right: 0; z-index: 10; width: 12rem; margin-top: .75rem; padding: 1rem; background: var(--background); border: 1px solid var(--line); }
  ul { display: grid; gap: .75rem; margin: 0; padding: 0; list-style: none; }
  @media (min-width: 42rem) { details { display: none; } }
</style>
