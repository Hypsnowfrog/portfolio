---
const { contact } = Astro.props;
const enabled = contact.form_enabled && contact.form_endpoint;
---
{enabled && <form action={contact.form_endpoint} method="post">
  <label>{contact.form_name_label}<input name="name" autocomplete="name" required /></label>
  <label>{contact.form_email_label}<input type="email" name="email" autocomplete="email" required /></label>
  <label>{contact.form_message_label}<textarea name="message" rows="7" required></textarea></label>
  <button type="submit">{contact.form_submit_label}</button>
</form>}
<style>
  form { display: grid; gap: 1.25rem; max-width: 38rem; margin-top: 3rem; } label { display: grid; gap: .5rem; } input, textarea { width: 100%; padding: .75rem; border: 1px solid var(--line); border-radius: 0; background: #fff; color: var(--text); } button { width: fit-content; padding: .75rem 1.25rem; border: 1px solid var(--text); border-radius: 0; background: var(--text); color: var(--background); }
</style>
