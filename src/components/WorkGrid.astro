---
import WorkCard from './WorkCard.astro';
import type { CollectionEntry } from 'astro:content';
interface Props { works: CollectionEntry<'works'>[]; enableFilters?: boolean; }
const { works, enableFilters = false } = Astro.props;
const categories = [...new Set(works.map((work) => work.data.category).filter((category): category is string => Boolean(category)))];
---
{enableFilters && categories.length > 1 && <div class="filters" aria-label="Filtrer les œuvres">
  <button type="button" data-filter="" aria-pressed="true">Tout</button>
  {categories.map((category) => <button type="button" data-filter={category} aria-pressed="false">{category}</button>)}
</div>}
<section class="work-grid" aria-label="Œuvres">
  {works.map((work) => <WorkCard work={work} />)}
</section>
<script>
  document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((button) => button.addEventListener('click', () => {
    const filter = button.dataset.filter ?? '';
    document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
    document.querySelectorAll<HTMLElement>('[data-work-card]').forEach((card) => {
      card.toggleAttribute('hidden', Boolean(filter && card.dataset.category !== filter));
    });
  }));
</script>
<style>
  .filters { display: flex; flex-wrap: wrap; gap: .5rem; margin: 2rem 0 3rem; }
  button { padding: .35rem 0; border: 0; border-bottom: 1px solid transparent; background: transparent; color: var(--muted); }
  button + button { margin-left: 1rem; }
  button[aria-pressed="true"] { border-color: var(--text); color: var(--text); }
  .work-grid { column-count: 1; column-gap: clamp(1rem, 3vw, 3rem); }
  @media (min-width: 42rem) { .work-grid { column-count: 2; } }
  @media (min-width: 68rem) { .work-grid { column-count: 3; } }
</style>
