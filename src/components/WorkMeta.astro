---
const { work, showStatus = false } = Astro.props;
---
<div class="work-meta">
  <p><span>{work.data.title}</span> <span>{work.data.year}</span></p>
  <p>{work.data.medium} · {work.data.dimensions}</p>
  {showStatus && work.data.status && <p>{work.data.status}</p>}
</div>
<style>
  .work-meta { padding-top: .75rem; color: var(--muted); font-size: .8125rem; line-height: 1.45; }
  p { margin: 0; } p + p { margin-top: .1rem; } p:first-child { color: var(--text); } p:first-child span:first-child { font-style: italic; }
</style>
